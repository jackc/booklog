[
  {
    "handler": "subroute",
    "routes": [
      {
        "match": [{"path": ["/assets/*"]}],
        "handle": [
          {
            "handler": "headers",
            "response": {
              "set": {
                "Cache-Control": [
                  "public, max-age=31536000, immutable"
                ]
              }
            }
          },
          {
            "handler": "file_server",
            "root": "{{.SlotDir}}/frontend",
            "precompressed": {
              "gzip": {},
              "zstd": {},
              "br": {}
            }
          }
        ]
      },
      {
        "handle": [
          {
            "handler": "reverse_proxy",
            "upstreams": [
              {
                "dial": "{{.Dial}}"
              }
            ]
          }
        ]
      }
    ]
  }
]
